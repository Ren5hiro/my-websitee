        <li><a href="education.html" class="active">Education</a></li>
        <li><a href="contact.html">References & Contact</a></li>
      </ul>
    </nav>
  </aside>

  <main id="main-content">
    <h1 class="trajectory-header">Educational <span>Trajectory</span></h1>
    
    <div class="timeline">
        
        <div class="timeline-item">
            <span class="status-label">Current / Undergraduate</span>
            <h3 class="school-name">De La Salle University - Manila</h3>
            <p class="description">
                Pursuing a <b>Bachelor of Science in Computer Engineering</b>. Focusing on hardware-software integration while serving as a <b>Samsung Student Ambassador</b>.
            </p>
        </div>

        <div class="timeline-item">
            <span class="status-label">Senior High School</span>
            <h3 class="school-name">University of Santo Tomas</h3>
            <p class="description">
                Graduated from the <b>Pontifical and Royal University</b> with honors, building a strong foundation for engineering studies and recognized for outstanding research output.
            </p>
        </div>

        <div class="timeline-item">
            <span class="status-label">Junior High School</span>
            <h3 class="school-name">University of Santo Tomas</h3>
            <p class="description">
                Developed core academic skills and participated in campus student life at España, Manila.
            </p>
        </div>

        <div class="timeline-item">
            <span class="status-label">Elementary (Grades 5 - 6) <span class="intl-tag">International</span></span>
            <h3 class="school-name">Yoshihara Elementary School</h3>
            <p class="description">
                Located in <b>Konanchou, Japan</b>. This period provided foundational international exposure and cultural immersion.
            </p>
        </div>

        <div class="timeline-item">
            <span class="status-label">Early Education (Kinder - Grade 4)</span>
            <h3 class="school-name">Uno High School</h3>
            <p class="description">
                Began primary education in a reputable Filipino-Chinese institution, fostering early academic discipline.
            </p>
        </div>

    </div>
  </main>

  <script src="js/main.js"></script>
</body>
</html>