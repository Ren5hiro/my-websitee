<!doctype html>
<html class="no-js" lang="en">
<head>
  <meta charset="utf-8">
  <title>Education | Rafael Papas</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  
  <style>
    /* 1. BASE THEME & LAYOUT */
    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
        font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
        /* Samsung Deep Black Background */
        background: #000; 
        color: #fff;
        display: flex;
        min-height: 100vh;
        margin: 0;
    }

    /* 2. SIDEBAR NAVIGATION */
    #sidebar {
        width: 280px;
        background: #000;
        color: #fff;
        padding: 50px 20px;
        position: fixed;
        height: 100vh;
        border-right: 2px solid #00aaff; /* Samsung Blue Border */
        z-index: 100;
    }

    .profile-img {
        width: 120px;
        height: 120px;
        border-radius: 50%;
        border: 3px solid #00aaff;
        display: block;
        margin: 0 auto 20px;
        object-fit: cover;
    }

    nav ul { list-style: none; margin-top: 30px; }
    nav li { margin-bottom: 5px; }
    nav a {
        color: #fff;
        text-decoration: none;
        font-size: 13px;
        display: block;
        padding: 12px 15px;
        transition: 0.3s;
    }
    nav a:hover { color: #00aaff; }
    nav a.active { background: #00aaff; border-radius: 5px; font-weight: bold; }

    /* 3. CONTENT AREA */
    #main-content {
        margin-left: 280px;
        padding: 80px 60px;
        width: 100%;
    }

    /* 4. EDUCATIONAL TRAJECTORY STYLING */
    .trajectory-header {
        font-size: 42px;
        font-weight: 800;
        margin-bottom: 60px;
        letter-spacing: -1px;
    }
    .trajectory-header span { color: #00aaff; }

    .timeline {
        position: relative;
        max-width: 900px;
        padding-left: 40px;
        border-left: 3px solid #00aaff;
    }

    .timeline-item {
        position: relative;
        margin-bottom: 50px;
    }

    /* Timeline Node Dots */
    .timeline-item::before {
        content: '';
        position: absolute;
        width: 18px;
        height: 18px;
        background-color: #000;
        border: 4px solid #00aaff;
        border-radius: 50%;
        left: -51px;
        top: 0;
        box-shadow: 0 0 10px rgba(0, 170, 255, 0.8);
    }

    .status-label {
        font-size: 10px;
        font-weight: 900;
        color: #00aaff;
        text-transform: uppercase;
        letter-spacing: 2px;
        margin-bottom: 8px;
        display: block;
    }

    .school-name {
        font-size: 24px;
        font-weight: 700;
        margin-bottom: 10px;
    }

    .description {
        font-size: 14px;
        color: #ccc;
        line-height: 1.6;
        max-width: 650px;
    }

    .intl-tag {
        background: #fff;
        color: #000;
        font-size: 10px;
        font-weight: 900;
        padding: 2px 10px;
        border-radius: 4px;
        margin-left: 10px;
        vertical-align: middle;
        text-transform: uppercase;
    }
  </style>
</head>
<body>

  <aside id="sidebar">
    <img src="img/profile.jpg" alt="Rafael Papas" class="profile-img">
    <div style="text-align: center;">
